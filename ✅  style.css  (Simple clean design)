root{
  --bg:#f7f7fb;
  --card:#ffffff;
  --text:#111;
  --muted:#666;
  --primary:#3b82f6;
  --border:#e6e6ef;
}

*{ box-sizing:border-box; }
body{
  margin:0;
  font-family: system-ui, Arial, sans-serif;
  background:var(--bg);
  color:var(--text);
}

.container{
  max-width: 820px;
  margin: 40px auto;
  padding: 0 16px;
}

h1{ margin: 0 0 12px; }
h2{ margin: 0 0 12px; }

.card{
  background:var(--card);
  border:1px solid var(--border);
  border-radius:14px;
  padding:16px;
  box-shadow: 0 10px 25px rgba(0,0,0,0.05);
  margin: 14px 0;
}

label{ display:block; margin:10px 0 6px; font-weight:600; }
input{
  width:100%;
  padding:12px;
  border:1px solid var(--border);
  border-radius:12px;
  outline:none;
}
input:focus{ border-color:var(--primary); }

.btn-row{ display:flex; gap:10px; flex-wrap:wrap; margin-top:12px; }
.btn{
  display:inline-block;
  background:var(--primary);
  color:white;
  padding:12px 16px;
  border:none;
  border-radius:12px;
  text-decoration:none;
  font-weight:700;
  cursor:pointer;
}
.btn-outline{
  background:transparent;
  color:var(--primary);
  border:2px solid var(--primary);
}

.muted{ color:var(--muted); }
.small{ font-size: 0.9rem; }

.topbar{
  display:flex;
  justify-content:space-between;
  align-items:center;
  gap:12px;
}
.games{
  display:grid;
  grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
  gap: 12px;
}

.game{
  background: var(--card);
  border:1px solid var(--border);
  border-radius:14px;
  padding:14px;
}
.game a{ color:var(--primary); font-weight:700; text-decoration:none; }
.game .remove{
  margin-top:10px;
  width:100%;
}

.grid{
  display:grid;
  grid-template-columns: 1fr 1fr auto;
  gap:10px;
}
@media (max-width: 620px){
  .grid{ grid-template-columns: 1fr; }
}
 
